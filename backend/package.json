{
  "name": "@git-plus/backend",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --target=node22 --external:better-sqlite3 --outfile=../dist/server/index.cjs && node scripts/copy-assets.mjs",
    "check:types": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-fastify": "^2.1.1",
    "@connectrpc/connect-node": "^2.1.1",
    "@fastify/http-proxy": "^11.4.0",
    "@fastify/static": "^8.3.0",
    "better-sqlite3": "^12.5.0",
    "croner": "^9.1.0",
    "fastify": "^5.6.2",
    "minimatch": "^10.1.1",
    "yazl": "^3.3.1",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.0",
    "@types/yazl": "^3.3.0",
    "esbuild": "^0.27.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
